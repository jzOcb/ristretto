{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ristretto",
  "version": "0.3.0",
  "identifier": "dev.ristretto.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Ristretto",
        "width": 1560,
        "height": 980,
        "minWidth": 1120,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
